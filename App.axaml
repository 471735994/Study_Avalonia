<Application
    x:Class="GetStartedApp.App"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:GetStartedApp"
    RequestedThemeVariant="Light">
    <!--  "Default" ThemeVariant follows system theme variant. "Dark" or "Light" are other available options.  -->

    <Application.DataTemplates>
        <local:ViewLocator />
    </Application.DataTemplates>

    <Application.Styles>
        <FluentTheme />
    </Application.Styles>

    <Application.Resources>
        <SolidColorBrush x:Key="LightBlueBrush" Color="#606875" />
        <SolidColorBrush x:Key="MidBlueBrush" Color="#373c44" />
        <SolidColorBrush x:Key="DarkBlueBrush" Color="#1a1c20" />
        <SolidColorBrush x:Key="FadedRedBrush" Color="#bc7c7a" />

    </Application.Resources>
</Application>
